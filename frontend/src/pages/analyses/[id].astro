---
import Layout from "../../layouts/Layout.astro";
import { AnalysisPage } from "@/components/analysis/AnalysisPage";
import { getInitialState } from "../../lib/server-i18n";

const { id } = Astro.params;
const { initialLanguagePreference, serverResolvedLang, initialThemePreference } = getInitialState(
  Astro.cookies,
  Astro.request
);

if (!id) {
  throw new Error("Missing analysis id parameter");
}
---

<Layout title={`Analysis ${id} · FAP Log Viewer`}>
  <AnalysisPage
    analysisId={id}
    client:load
    initialLanguagePreference={initialLanguagePreference}
    initialLanguage={serverResolvedLang}
    initialThemePreference={initialThemePreference}
  />
</Layout>
