---
import "../styles/global.css";

interface Props {
  title?: string;
}

import { getInitialState } from "../lib/server-i18n";

const { title = "10x Astro Starter" } = Astro.props;

const { initialLanguagePreference, serverResolvedLang, initialThemePreference } = getInitialState(
  Astro.cookies,
  Astro.request
);
---

<!doctype html>
<html lang={serverResolvedLang} data-language-preference={initialLanguagePreference} data-theme-preference={initialThemePreference}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" href="/favicon.svg">
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (function () {
        const themeStorageKey = "fap-log-viewer-theme";
        const langStorageKey = "fap-log-viewer-language";
        const themeMediaQuery = "(prefers-color-scheme: dark)";
        const root = document.documentElement;

        // Theme logic
        const applyTheme = (theme) => {
          root.classList.toggle("dark", theme === "dark");
          root.dataset.theme = theme;
          root.style.colorScheme = theme === "dark" ? "dark light" : "light dark";
        };

        const setThemePreferenceDataset = (preference) => {
          root.dataset.themePreference = preference;
        };

        const safelyReadThemeStorage = () => {
          try {
            const match = document.cookie.match(new RegExp('(^| )' + themeStorageKey + '-preference=([^;]+)'));
            if (match && (match[2] === "light" || match[2] === "dark" || match[2] === "system")) {
              return match[2];
            }
            const stored = window.localStorage.getItem(themeStorageKey);
            return stored === "light" || stored === "dark" ? stored : null;
          } catch (error) {
            return null;
          }
        };

        const themePreference = safelyReadThemeStorage() ?? "system";
        const themeMedia = window.matchMedia ? window.matchMedia(themeMediaQuery) : null;
        const systemPrefersDark = themeMedia ? themeMedia.matches : false;
        const resolvedTheme = themePreference === "system" ? (systemPrefersDark ? "dark" : "light") : themePreference;

        applyTheme(resolvedTheme);
        setThemePreferenceDataset(themePreference);

        // Language logic
        const applyLanguage = (lang) => {
          root.lang = lang;
        };

        const setLanguagePreferenceDataset = (preference) => {
          root.dataset.languagePreference = preference;
        };

        const safelyReadLangStorage = () => {
          try {
            const match = document.cookie.match(new RegExp('(^| )' + langStorageKey + '-preference=([^;]+)'));
            if (match && (match[2] === "en" || match[2] === "pl" || match[2] === "system")) {
              return match[2];
            }
            const stored = window.localStorage.getItem(langStorageKey);
            return stored === "en" || stored === "pl" ? stored : null;
          } catch (error) {
            return null;
          }
        };

        const isSupportedLang = (l) => l === "en" || l === "pl";

        const detectSystemLang = () => {
          const preferred = navigator.languages?.[0] ?? navigator.language;
          if (preferred) {
            const [lang] = preferred.toLowerCase().split("-");
            if (isSupportedLang(lang)) return lang;
          }
          return "en";
        };

        const langPreference = safelyReadLangStorage() ?? "system";
        const resolvedLang = langPreference === "system" ? detectSystemLang() : langPreference;

        applyLanguage(resolvedLang);
        setLanguagePreferenceDataset(langPreference);
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
